(backend_proxy) {
	# Consultation SSE must flush incrementally instead of being buffered.
	reverse_proxy backend:8000 {
		flush_interval -1
		health_uri /api/v1/health
		health_interval 30s
		health_timeout 5s
		transport http {
			dial_timeout 10s
			response_header_timeout 30s
			read_timeout 3600s
			write_timeout 3600s
		}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}
	}
}

api-staging.smartchildcareagent.cn {
	import backend_proxy
}

# Temporary HTTP-only debug entry for manual VPS troubleshooting before DNS/TLS is ready.
http://150.109.77.178 {
	import backend_proxy
}
