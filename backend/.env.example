# Local development template for the FastAPI backend.
# For Tencent Cloud VPS staging, copy backend/.env.release.example to backend/.env.release
# and inject real VIVO_APP_ID / VIVO_APP_KEY only on the server.
APP_NAME=SmartChildcare Agent Brain
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,https://your-vercel-staging.vercel.app,https://your-frontend.example.com
ENABLE_MOCK_PROVIDER=true
BRAIN_PROVIDER=vivo
BRAIN_TIMEOUT_MS=20000

# vivo text provider credentials (server-side only, never commit real values)
VIVO_APP_ID=
VIVO_APP_KEY=
VIVO_BASE_URL=https://api-ai.vivo.com.cn
VIVO_LLM_MODEL=Volc-DeepSeek-V3.2
VIVO_OCR_PATH=/ocr/general_recognition
VIVO_EMBEDDING_MODEL=m3e-base
STORYBOOK_IMAGE_PROVIDER=mock
STORYBOOK_AUDIO_PROVIDER=auto
STORYBOOK_TTS_ENGINEID=short_audio_synthesis_jovi
STORYBOOK_TTS_VOICE=yige
STORYBOOK_TTS_FALLBACK_ENGINEID=short_audio_synthesis_jovi
STORYBOOK_TTS_FALLBACK_VOICE=vivoHelper

# Memory backend.
# Local development can keep the repo-local SQLite path.
# VPS staging should prefer /data/agent-memory.db via backend/.env.release.
# Legacy Render staging may still override this to /tmp/agent-memory.db.
BRAIN_MEMORY_BACKEND=sqlite
MYSQL_URL=
BRAIN_MEMORY_SQLITE_PATH=backend/.local/agent-memory.db
REQUEST_TIMEOUT_SECONDS=20

# VPS staging recommended overrides:
# ENVIRONMENT=staging
# LOG_LEVEL=INFO
# ALLOW_ORIGINS=https://your-vercel-staging.vercel.app,https://your-frontend.example.com
# ENABLE_MOCK_PROVIDER=false
# BRAIN_PROVIDER=vivo
# BRAIN_MEMORY_BACKEND=sqlite
# BRAIN_MEMORY_SQLITE_PATH=/data/agent-memory.db
#
# Legacy Render override:
# BRAIN_MEMORY_SQLITE_PATH=/tmp/agent-memory.db
#
# Supported backend env lookup priority:
# BRAIN_ENV_FILE > backend/.env.local > repo/.env.local > backend/.env.release > repo/.env.release > backend/.env > repo/.env
