# Copy this file to .env.release at the repo root for Tencent Cloud VPS staging.
# This single file is intentionally shared by:
# 1. Docker Compose backend deployment
# 2. Next.js/Vercel server-side bridge settings
# 3. Existing release gate scripts
#
# Never commit real VIVO_APP_ID / VIVO_APP_KEY.

# Release gate / remote verification
RELEASE_BASE_URL=https://your-vercel-staging.vercel.app
RELEASE_ADMIN_COOKIE=
CRON_SECRET=
RELEASE_REPORT_PATH=./release-report.json

# Next.js server-side bridge
# The browser should still call Next /api/ai/* routes.
BRAIN_API_BASE_URL=https://api-staging.smartchildcareagent.cn
NEXT_PUBLIC_BACKEND_BASE_URL=
# Increase this budget on staging so real remote brain calls do not
# immediately fall back to the local Next.js handlers.
BRAIN_API_TIMEOUT_MS=45000

# Optional Next.js snapshot persistence
DATABASE_URL=
DATABASE_SSL=true
NEXT_PUBLIC_FORCE_MOCK_MODE=false

# Minimal auth session and default passwords
AUTH_SESSION_SECRET=
AUTH_DEFAULT_PASSWORD=123456
AUTH_PASSWORD_U_ADMIN=
AUTH_PASSWORD_U_TEACHER=
AUTH_PASSWORD_U_TEACHER2=
AUTH_PASSWORD_U_PARENT=

# Optional server-side suggestion provider for existing Next.js flows
DASHSCOPE_API_KEY=
BAILIAN_MODEL=qwen-plus
BAILIAN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
BAILIAN_TIMEOUT_MS=12000

# FastAPI backend runtime for Tencent Cloud VPS staging
APP_NAME=SmartChildcare Agent Brain
APP_VERSION=0.1.0
ENVIRONMENT=staging
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
APP_HOST=0.0.0.0
APP_PORT=8000
PORT=8000
# Replace both origins with the real release/preview domains before deploy.
# Leaving placeholder values here should be treated as a staging misconfiguration.
ALLOW_ORIGINS=https://your-real-release.example.com,https://your-real-preview.example.com
ENABLE_MOCK_PROVIDER=false
BRAIN_PROVIDER=vivo
BRAIN_TIMEOUT_MS=45000
REQUEST_TIMEOUT_SECONDS=45

# vivo provider credentials and models
VIVO_APP_ID=
VIVO_APP_KEY=
VIVO_BASE_URL=https://api-ai.vivo.com.cn
VIVO_LLM_MODEL=Volc-DeepSeek-V3.2
VIVO_OCR_PATH=/ocr/general_recognition
VIVO_EMBEDDING_MODEL=m3e-base
STORYBOOK_IMAGE_PROVIDER=vivo
STORYBOOK_AUDIO_PROVIDER=vivo
STORYBOOK_TTS_ENGINEID=tts_humanoid_lam
STORYBOOK_TTS_VOICE=F245_natural
STORYBOOK_TTS_MODEL=
STORYBOOK_TTS_PRODUCT=
STORYBOOK_TTS_PACKAGE=
STORYBOOK_TTS_CLIENT_VERSION=
STORYBOOK_TTS_SYSTEM_VERSION=
STORYBOOK_TTS_SDK_VERSION=
STORYBOOK_TTS_ANDROID_VERSION=

# Backend memory persistence
BRAIN_MEMORY_BACKEND=sqlite
BRAIN_MEMORY_SQLITE_PATH=/data/agent-memory.db
MYSQL_URL=

# Optional mini-program integration settings
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_SUBSCRIBE_TEMPLATE_ID=
WECHAT_MINI_PROGRAM_PAGE=pages/index/index

# Notification dispatch provider: mock | wechat
NOTIFICATION_PROVIDER=mock
CRON_DISPATCH_LIMIT_PER_INSTITUTION=100
