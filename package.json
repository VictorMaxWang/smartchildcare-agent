{
  "name": "childcare-smart",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "ai:smoke": "node ./scripts/ai-suggestions-smoke.mjs",
    "release:check": "node ./scripts/release-check.mjs",
    "release:report": "node ./scripts/release-check.mjs",
    "release:report:local": "node ./scripts/release-check.mjs --report-path=./artifacts/release-report.local.json",
    "release:check:remote": "node ./scripts/release-check.mjs --require-remote",
    "release:report:remote": "node ./scripts/release-check.mjs --require-remote --report-path=./artifacts/release-report.remote.json",
    "release:gate:local": "npm run lint && npm run build && npm run release:check",
    "release:gate:remote": "npm run release:check:remote",
    "release:gate:remote:env": "node ./scripts/release-check.mjs --require-remote --release-env-file=.env.release --report-path=./artifacts/release-report.remote.json",
    "release:env:init": "node ./scripts/release-env-init.mjs",
    "release:env:check": "node ./scripts/release-env-check.mjs",
    "release:remote:reset": "node ./scripts/release-remote-reset.mjs",
    "release:go:remote": "npm run release:remote:reset && npm run release:env:init && npm run release:env:check && npm run release:gate:remote:env",
    "release:go:all": "npm run release:gate:local && npm run release:go:remote",
    "release:sql:pass": "node ./scripts/release-sql-check-set.mjs --overall-passed=true",
    "release:sql:fail": "node ./scripts/release-sql-check-set.mjs --overall-passed=false",
    "release:status": "node ./scripts/release-status.mjs",
    "release:ready": "node ./scripts/release-ready.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.99.0",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.2.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
