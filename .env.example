# Local development defaults for the shared root env surface.
# Use local-only files for real secrets if this file is kept in git.

# Optional Next.js state snapshot persistence
DATABASE_URL=
DATABASE_SSL=true
NEXT_PUBLIC_FORCE_MOCK_MODE=false

# Minimal auth session and default passwords (MVP)
AUTH_SESSION_SECRET=
AUTH_DEFAULT_PASSWORD=123456
AUTH_PASSWORD_U_ADMIN=
AUTH_PASSWORD_U_TEACHER=
AUTH_PASSWORD_U_TEACHER2=
AUTH_PASSWORD_U_PARENT=

# Alibaba Cloud Bailian (DashScope) for existing Next.js server-side suggestions
DASHSCOPE_API_KEY=
BAILIAN_MODEL=qwen-plus
BAILIAN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
BAILIAN_TIMEOUT_MS=12000

# FastAPI backend runtime for local development
APP_NAME=SmartChildcare Agent Brain
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
APP_HOST=0.0.0.0
APP_PORT=8000
PORT=8000
ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
ENABLE_MOCK_PROVIDER=true
BRAIN_PROVIDER=mock
BRAIN_TIMEOUT_MS=20000
REQUEST_TIMEOUT_SECONDS=20

# Leave secrets empty in tracked files.
VIVO_APP_ID=
VIVO_APP_KEY=
VIVO_BASE_URL=https://api-ai.vivo.com.cn
VIVO_LLM_MODEL=Volc-DeepSeek-V3.2
VIVO_OCR_PATH=/ocr/general_recognition
VIVO_EMBEDDING_MODEL=m3e-base

# FastAPI Agent memory hub
MYSQL_URL=
BRAIN_MEMORY_BACKEND=sqlite
BRAIN_MEMORY_SQLITE_PATH=backend/.local/agent-memory.db

# FastAPI brain service bridge
# Local dev: http://127.0.0.1:8000
# Vercel staging: https://api-staging.smartchildcareagent.cn
BRAIN_API_BASE_URL=http://127.0.0.1:8000
# Optional debug mirror for surfacing the backend origin in the UI.
# Do not use this as the primary consultation transport.
# The browser should still call Next /api/ai/* routes.
NEXT_PUBLIC_BACKEND_BASE_URL=
BRAIN_API_TIMEOUT_MS=20000

# Optional mini-program integration settings
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_SUBSCRIBE_TEMPLATE_ID=
WECHAT_MINI_PROGRAM_PAGE=pages/index/index

# Notification dispatch provider: mock | wechat
NOTIFICATION_PROVIDER=mock

# Cron dispatch protection and batch size
CRON_SECRET=
CRON_DISPATCH_LIMIT_PER_INSTITUTION=100

# Release gate remote checks (optional for local, required for CI remote gate)
RELEASE_BASE_URL=
RELEASE_ADMIN_COOKIE=
RELEASE_REPORT_PATH=./release-report.json
